# Bark Push Notification Configuration
# ======================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Or run the setup script with your Bark URL:
#   python3 scripts/setup.py "https://your-server.com/YOUR_KEY/test"
#
# The Bark URL can be found in the Bark iOS app — just copy the example URL.

# ---- Required ----

# Your Bark device key (extracted from the Bark URL)
BARK_KEY=

# Your Bark server base URL (no trailing slash)
# Examples:
#   https://api.day.app              (official server)
#   https://bark.example.com         (self-hosted)
#   https://example.com:8080         (self-hosted with custom port)
BARK_BASE_URL=https://api.day.app

# ---- Optional ----

# Machine/device name shown in task-completion notifications
# BARK_MACHINE_NAME=My-Mac

# ---- Encryption (optional, for end-to-end encrypted push) ----
# Must match the settings configured in the Bark iOS app.
#
# Algorithm: AES128 / AES192 / AES256
# BARK_ENCRYPT_ALGORITHM=
# Mode: CBC / ECB / GCM  (default: CBC)
# BARK_ENCRYPT_MODE=
# Key: raw UTF-8 string, length must match algorithm (16/24/32 bytes)
# BARK_ENCRYPT_KEY=
# IV: raw UTF-8 string (16 bytes for CBC, 12 bytes for GCM, not needed for ECB)
# BARK_ENCRYPT_IV=
